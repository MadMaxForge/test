# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_token_here

# OpenRouter API Key
OPENROUTER_API_KEY=your_key_here

# Google Apps Script Web App URL (after deploying the script)
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Security token for Google Apps Script (set the same value in Code.gs)
GOOGLE_SCRIPT_TOKEN=your_random_secret_token_here

# Owner Telegram Chat ID (0 = auto-register first user)
OWNER_CHAT_ID=0

# LLM Model (OpenRouter)
LLM_MODEL=google/gemini-2.5-flash

# Reminder settings
REMINDER_CHECK_INTERVAL=120
REMINDER_BEFORE_MINUTES=15,5

# Timezone
TIMEZONE=Europe/Moscow

# Daily digest time
DAILY_DIGEST_HOUR=8
DAILY_DIGEST_MINUTE=0

# Database path
DB_PATH=calendar_bot.db
