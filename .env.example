# OpenRouter API (LLM for agents)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Evolink API (Nano Banana 2 + Kling Motion Control)
EVOLINK_API_KEY=sk-your-evolink-key-here

# RunPod API (Z-Image Turbo)
RUNPOD_API_KEY=rpa_your-runpod-key-here
RUNPOD_ENDPOINT=your-endpoint-id-here

# Mission Control
MC_AUTH_TOKEN=your-mc-token-here

# Workspace path
OPENCLAW_WORKSPACE=/root/.openclaw/workspace
