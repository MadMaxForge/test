# ── Required API Keys ────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789
EVOLINK_API_KEY=evo-...

# ── ComfyUI (Z-Image via SSH tunnel) ────────────────────────────
# SSH tunnel: laptop:8001 -> VPS localhost:8001
# On laptop: ssh -R 8001:localhost:8001 -p 2222 root@<VPS_IP>
COMFYUI_URL=http://127.0.0.1:8001

# ── Optional: Instagram Session ──────────────────────────────────
# INSTA_SESSION_ID=your_session_id

# ── Optional: Workspace Path ─────────────────────────────────────
# CONTENT_WORKSPACE=/root/.openclaw/workspace

# ── Optional: LLM Model Overrides ────────────────────────────────
# MODEL_ANALYST=google/gemini-2.0-flash-lite-001
# MODEL_PLANNER=moonshotai/kimi-k2.5
# MODEL_CREATIVE=moonshotai/kimi-k2.5
# MODEL_PUBLISH=google/gemini-2.0-flash-lite-001
